<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121214">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".VideoEditFragment">

        <!-- Header Toolbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1A1A1E"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#FFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Editor"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Video Workspace Card Container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVideoContainer"
            android:layout_width="match_parent"
            android:layout_height="340dp"
            android:layout_margin="16dp"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutHeader">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- TextureView for Media Player Rendering -->
                <TextureView
                    android:id="@+id/videoTextureView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Transparent Overlay view for real-time Face overlays -->
                <ImageView
                    android:id="@+id/overlayView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Control Panel -->
        <LinearLayout
            android:id="@+id/layoutControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1E"
            android:elevation="12dp"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@+id/cardVideoContainer"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0">

            <!-- Emoji Selector Panel (Visible only when EMOJI effect is chosen) -->
            <HorizontalScrollView
                android:id="@+id/scrollEmojiPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:scrollbars="none"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/emoji1"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="😊"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/emoji2"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="😎"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/emoji3"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="🐱"
                        android:textSize="32sp" />

                    <TextView
                        android:id="@+id/emoji4"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:text="❤️"
                        android:textSize="32sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Effects Horizontal Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="SELECT EFFECT"
                android:textColor="#8A8A8F"
                android:textSize="11sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- NONE -->
                    <Button
                        android:id="@+id/btnEffectNone"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#2C2C30"
                        android:text="Original"
                        android:textColor="#FFFFFF" />

                    <!-- BLUR -->
                    <Button
                        android:id="@+id/btnEffectBlur"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#2C2C30"
                        android:text="Blur"
                        android:textColor="#FFFFFF" />

                    <!-- PIXELATE -->
                    <Button
                        android:id="@+id/btnEffectPixelate"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#2C2C30"
                        android:text="Pixelate"
                        android:textColor="#FFFFFF" />

                    <!-- BLACKOUT -->
                    <Button
                        android:id="@+id/btnEffectBlackout"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#2C2C30"
                        android:text="Blackout"
                        android:textColor="#FFFFFF" />

                    <!-- EMOJI -->
                    <Button
                        android:id="@+id/btnEffectEmoji"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#2C2C30"
                        android:text="Emoji"
                        android:textColor="#FFFFFF" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnExport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#7C4DFF"
                android:text="Export &amp; Save Video"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="28dp" />

        </LinearLayout>

        <!-- Full-screen Loading / Progress overlay -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutProgressOverlay"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#E6121214"
            android:elevation="24dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:progressTint="#7C4DFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/progressBar"
                app:layout_constraintStart_toStartOf="@+id/progressBar"
                app:layout_constraintTop_toBottomOf="@+id/progressBar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Processing Video frames with ML Kit..."
                android:textColor="#8A8A8F"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtProgressPercent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>