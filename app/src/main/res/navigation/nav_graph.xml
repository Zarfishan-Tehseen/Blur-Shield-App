<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.blurshieldapp.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_edit"
            app:destination="@id/editFragment" />
    </fragment>

    <fragment
        android:id="@+id/editFragment"
        android:name="com.example.blurshieldapp.ui.edit.EditFragment"
        android:label="Edit Faces">
        <argument
            android:name="imageUri"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/videoEditFragment"
        android:name="com.example.blurshieldapp.ui.video.VideoEditFragment"
        android:label="Edit Video">
        <argument
            android:name="videoUri"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/exportFragment"
        android:name="com.example.blurshieldapp.ui.export.ExportFragment"
        android:label="Export"
        tools:layout="@layout/fragment_export" />

</navigation>